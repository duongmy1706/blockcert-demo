# MongoDB
MONGODB_URI_LOCAL=mongodb://localhost:27017/blockchaincertificate

# Server
PORT=4000
LOG_LEVEL=debug

# Session
EXPRESS_SESSION_SECRET=blockcert-vanlang-super-secret-2024-change-this

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Fabric
# Đường dẫn tuyệt đối đến file connection profile của org1
# Ví dụ: /home/user/Veritas-Ledger/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/connection-org1.json
CCP_PATH=

FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=educert

# Wallet path (để lưu identity sau khi enroll)
WALLET_PATH=./wallet

# true nếu chạy local (discovery dùng localhost), false nếu deploy
AS_LOCALHOST=true
